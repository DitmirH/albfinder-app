# AlbFinder – copy to .env and fill in

# Auth: JSON object of email -> password
VITE_USERS={"email@example.com":"yourpassword"}

# Supabase (optional – if set, app uses Supabase for data instead of static data.json)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# For seed script only (optional – can use anon key instead)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
